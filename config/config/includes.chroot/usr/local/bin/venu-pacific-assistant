# --- Conversation persistence ----------------------------------------------
#
# One JSON file per conversation under ~/.local/share, matching the XDG data
# convention rather than inventing a new dotfile location. Deliberately not
# a single combined history file -- deleting one conversation is then just
# deleting one file, and a corrupt/partial write to one conversation can't
# take the whole history down with it.
#
# Conversations are saved after every completed turn (not just when the
# user switches away or closes the window) so a crash or force-quit never
# loses more than the in-flight reply -- the same "never fail silently"
# principle behind AssistantStartupError above.

DATA_DIR = os.path.expanduser("~/.local/share/venu-pacific-assistant")
CONVERSATIONS_DIR = os.path.join(DATA_DIR, "conversations")
TITLE_MAX_CHARS = 40


def _conversation_path(conv_id):
    return os.path.join(CONVERSATIONS_DIR, f"{conv_id}.json")


def _make_title(text):
    collapsed = " ".join(text.split())
    if len(collapsed) <= TITLE_MAX_CHARS:
        return collapsed
    return collapsed[: TITLE_MAX_CHARS - 1].rstrip() + "…"


def _list_conversations():
    """Newest-first list of {id, title, updated} -- reads just enough of
    each file to build the sidebar, not the full message history."""
    if not os.path.isdir(CONVERSATIONS_DIR):
        return []
    conversations = []
    for path in glob.glob(os.path.join(CONVERSATIONS_DIR, "*.json")):
        try:
            with open(path, "r", encoding="utf-8") as f:
                data = json.load(f)
            conversations.append(
                {
                    "id": data["id"],
                    "title": data.get("title") or _("Untitled conversation"),
                    "updated": data.get("updated", ""),
                }
            )
        except Exception:
            # A corrupt/partial file shouldn't take the whole sidebar down --
            # skip it rather than crash the app on startup.
            continue
    conversations.sort(key=lambda c: c["updated"], reverse=True)
    return conversations


def _load_conversation(conv_id):
    try:
        with open(_conversation_path(conv_id), "r", encoding="utf-8") as f:
            return json.load(f)
    except Exception:
        return None


def _save_conversation(conv_id, title, messages):
    os.makedirs(CONVERSATIONS_DIR, exist_ok=True)
    data = {
        "id": conv_id,
        "title": title,
        "updated": datetime.datetime.now().isoformat(timespec="seconds"),
        "messages": messages,
    }
    path = _conversation_path(conv_id)
    tmp_path = path + ".tmp"
    # Write-then-rename so a crash mid-write never leaves a half-written
    # JSON file behind that _load_conversation would then have to reject.
    with open(tmp_path, "w", encoding="utf-8") as f:
        json.dump(data, f, ensure_ascii=False, indent=2)
    os.replace(tmp_path, path)


def _delete_conversation(conv_id):
    try:
        os.remove(_conversation_path(conv_id))
    except FileNotFoundError:
        pass


class AssistantStartupError(Exception):
    """Raised with a specific, user-facing reason -- the caller must never
    let a startup failure disappear silently (that was the earlier bug:
    the UI stayed on "Starting the assistant..." forever with no feedback
    if llama-server failed to launch for any reason)."""


def _server_port_responds():
    """True if ANYTHING answers HTTP on the server port -- a 200, or a 503
    while a login-started service is still loading the model. Either way
    a server exists and this app must not spawn a second one on the same
    port; only connection-refused means nothing is there."""
    try:
        urllib.request.urlopen(f"{SERVER_URL}/health", timeout=2)
        return True
    except urllib.error.HTTPError:
        return True
    except Exception:
        return False


class LlamaServerManager:
    """Connects to the login-started model server when one exists
    (venu-pacific-llama.service -- started at session login so the
    model's slow cold disk read happens in the background before the
    user ever opens this window, and sleeps/frees its RAM after 10 idle
    minutes). Falls back to spawning llama-server itself when the
    service isn't there (service disabled, failed, or running the app
    outside the shipped image) -- in which case this keeps the original
    on-demand lifecycle: spawned here, killed when the window closes."""

    def __init__(self):
        self.process = None
        self.external = False

    def start(self):
        if self.process is not None or self.external:
            return
        if _server_port_responds():
            self.external = True
            return
        if not os.path.exists(LLAMA_SERVER_BIN):
            raise AssistantStartupError(
                _("llama-server is missing ({path}).").format(path=LLAMA_SERVER_BIN)
            )
        if not os.path.exists(MODEL_PATH):
            raise AssistantStartupError(
                _("The assistant model is missing ({path}).").format(path=MODEL_PATH)
            )
        try:
            # llama-server's own stderr (startup errors, request-validation
            # failures, template-rendering errors) was previously discarded
            # entirely -- confirmed this makes server-side errors (like a
            # 400 response) undiagnosable from the client side alone.
            # Truncated fresh each start, not appended, so it can't grow
            # unbounded across many sessions -- only the current run's log
            # is ever useful for diagnosis anyway.
            os.makedirs(DATA_DIR, exist_ok=True)
            self._log_path = os.path.join(DATA_DIR, "llama-server.log")
            log_file = open(self._log_path, "w", encoding="utf-8", errors="replace")
            self.process = subprocess.Popen(
                [
                    LLAMA_SERVER_BIN,
                    "-m", MODEL_PATH,
                    "--port", str(SERVER_PORT),
                    "--host", "127.0.0.1",
                    # 8192, a deliberate middle. 4096 was too small,
                    # confirmed live: ~3,500 tokens of fixed overhead
                    # (system prompt + all tool schemas, sent on every
                    # request) plus a 500-token generation reserve left
                    # ~80 tokens for conversation history, causing real
                    # context-overflow 400s mid-conversation. But the
                    # 16384 this was first raised to had its own measured
                    # cost: llama-server allocates AND zeroes the whole KV
                    # cache eagerly at startup (committed RAM whether used
                    # or not) -- ~2.3GiB f16 at 16384, enough on an 8GB
                    # machine to evict the model file from the page cache
                    # and make later cold starts slower. 8192 with the
                    # q8_0 KV quantization below is ~0.6GiB, leaves ~4,200
                    # tokens of real history room, and the client already
                    # detects overflow and tells the user to start a new
                    # chat, so very long conversations degrade with a
                    # clear message rather than a crash. Keep in sync with
                    # venu-pacific-llama.service (same argument list).
                    "-c", "8192",
                    # Required for tool-calling as of current llama.cpp --
                    # confirmed in source (tools/server/server-common.cpp):
                    # a request with `tools`/`tool_choice` is rejected with
                    # HTTP 400 ("tools param requires --jinja flag")
                    # without this. Has been working without it so far only
                    # because the currently-built binary predates that
                    # requirement -- the build hook now pins a release tag
                    # (see 0170-venu-pacific-ai-assistant.hook.chroot) so
                    # these flags and the binary's semantics stay matched.
                    "--jinja",
                    # One slot with the full 16384 context dedicated to it.
                    # The current default (--parallel -1) auto-resolves to
                    # FOUR slots sharing a unified KV buffer -- sensible for
                    # a multi-user server, pointless for this app's single
                    # conversation-at-a-time use, and it makes slot
                    # selection/caching behavior version-dependent.
                    # Explicit -np 1 pins the simple, deterministic case:
                    # every request LCP-matches the same slot, so the
                    # ~3,500-token system-prompt+tools prefix stays cached
                    # across requests instead of re-evaluating (~2 minutes
                    # of prompt processing at this hardware's ~30 tok/s).
                    "-np", "1",
                    # Recovers cached KV after mid-prompt divergences by
                    # shifting still-matching chunks (>=256 consecutive
                    # tokens) into their new positions instead of
                    # recomputing them. Matters here because Qwen3's chat
                    # template strips <think> blocks from previous
                    # assistant turns when re-rendering, so the cached
                    # tokens and the re-sent history diverge slightly at
                    # every turn boundary -- plain prefix matching stops at
                    # the first difference, this recovers what follows. 256
                    # is llama.cpp's own value in its built-in server
                    # presets.
                    "--cache-reuse", "256",
                    # NOTE: -fa on / -ctk q8_0 / -ctv q8_0 were tried here
                    # (flash attention + quantized KV cache, to save KV RAM)
                    # and REVERTED after real measurement. The research that
                    # suggested them called CPU flash-attention "neutral to
                    # slightly-positive" -- but on the actual (virtualized)
                    # target hardware it roughly HALVED prompt-processing
                    # speed: 13.1 tok/s with the flags vs ~31 tok/s without,
                    # confirmed from llama-server's own print_timing logs on
                    # a real install. Clean attribution: a live-patch test
                    # of the same client against the OLD server (no flags)
                    # was fast; the rebuild that added these flags was slow.
                    # The KV RAM they saved (~0.5GiB at -c 8192) isn't worth
                    # doubling the wait for the first reply on this class of
                    # machine. f16 KV at 8192 (~1.1GiB) fits the 8GB budget
                    # fine. Don't re-add these without benchmarking on the
                    # actual target CPU first.
                ],
                stdout=log_file,
                stderr=subprocess.STDOUT,
            )
            log_file.close()  # the child already inherited the fd; safe to close our copy
        except OSError as exc:
            raise AssistantStartupError(
                _("Could not launch llama-server: {error}").format(error=exc)
            )

    def wait_ready(self, timeout=STARTUP_TIMEOUT_SECONDS):
        deadline = time.time() + timeout
        while time.time() < deadline:
            # self.process is None when connected to the login-started
            # service (nothing of ours to crash-check) -- health polling
            # below covers it either way, including the case where that
            # service is still mid-load and answering 503.
            if self.process is not None and self.process.poll() is not None:
                raise AssistantStartupError(
                    _("llama-server exited unexpectedly (code {code}).").format(
                        code=self.process.returncode
                    )
                )
            try:
                urllib.request.urlopen(f"{SERVER_URL}/health", timeout=2)
                return
            except Exception:
                time.sleep(0.5)
        raise AssistantStartupError(_("Timed out waiting for the assistant to start."))

    def stop(self):
        # Only ever stops a server this app spawned itself. The
        # login-started service manages its own lifecycle (sleeps and
        # frees its RAM after idle) -- killing it here would throw away
        # the warm model/KV state that makes the next app open instant,
        # exactly the thing the service exists to provide.
        if self.process is None:
            return
        self.process.terminate()
        try:
            self.process.wait(timeout=5)
        except subprocess.TimeoutExpired:
            self.process.kill()
        self.process = None


SYSTEM_PROMPT = (
    "You are a helpful offline assistant. Keep answers concise. For any answer "
    "longer than one or two sentences, break it into short paragraphs separated "
    "by blank lines instead of one long block of text -- this is displayed in a "
    "narrow chat window, so readability matters more than a single flowing "
    "paragraph.\n\n"
    "For calculations and numbers, write them in plain text only, e.g. "
    "'48 × 3,750 = 180,000' -- never use LaTeX or markdown math notation "
    "(no \\text{}, \\times, \\frac{}{}, or $...$ delimiters). The chat display "
    "cannot render math typesetting, so LaTeX shows up as literal backslashes "
    "and braces instead of a readable equation.\n\n"
    "Whenever you need to check something you can check (disk space, Wi-Fi, "
    "internet, printers, open windows, active window, the time, battery), "
    "call the matching tool in that same turn. Never say \"let me check\" or "
    "\"I will check\" as a sentence on its own without actually calling the "
    "tool right then -- that leaves the user with no answer at all. Call the "
    "tool, then answer using its real result.\n\n"
    "For ANY question about disaster/emergency safety (cyclone, tsunami, "
    "earthquake) or official government/health/education procedures "
    "(passports, business registration, hospitals, schools, etc.) in "
    "Vanuatu or Fiji, you MUST call get_disaster_info or get_services_info "
    "first and answer only from what they return -- never answer these "
    "topics from general knowledge. If the tool says the country or topic "
    "isn't covered, say so honestly. Do not fall back to generic or "
    "other-country knowledge (e.g. do not describe a US, UK, or Australian "
    "government process for a Vanuatu or Fiji question) -- wrong-country "
    "official information is worse than admitting you don't have it.\n\n"
    "For general knowledge questions (not disaster/government-specific), check "
    "list_offline_encyclopedias then search the available offline reference collections "
    "(always includes Vikidia, a children's encyclopedia; may also include MedlinePlus, "
    "Wikipedia Vital Articles, or Gutenberg Education/Agriculture if the user has "
    "downloaded them) before answering from your own training if you're not confident. "
    "These are aimed at general/simplified explanations, so they may not cover advanced "
    "or very specific topics, but prefer a verified source when one exists.\n\n"
    "If a general knowledge question isn't answered by the offline reference collections, "
    "tell the user honestly that you couldn't find it locally, then say you'll check the "
    "internet, then call search_internet. Do NOT do this for disaster/government-service "
    "questions -- get_disaster_info and get_services_info's 'say so honestly, never fall "
    "back to generic knowledge' rule stays absolute; search_internet is only for general "
    "knowledge topics, never as a substitute for those two tools. search_internet requires "
    "the user's approval and will report 'no internet available' on its own if there's no "
    "connection -- if that happens, tell the user honestly that you have no way to answer "
    "that offline.\n\n"
    "You can ONLY do what the available tools let you do: check disk space, "
    "check Wi-Fi status, check internet connectivity, check printer status, "
    "check the print queue, cancel stuck print jobs, "
    "list open windows, check which window is active, check the current "
    "date/time, check battery status, look up disaster safety info, look up "
    "government/health/education services, list/search/read offline reference "
    "collections, search the internet for general knowledge as a last resort, "
    "list installed applications, open an installed application, close a specific "
    "open window (by its normal close request, giving unsaved work its usual chance "
    "to prompt -- never a forced kill), "
    "open the Wi-Fi settings app, open the printer settings app, read a "
    "text file or extract the text of a PDF document in the user's home directory, "
    "create or overwrite a text file in "
    "the user's home directory, and find files by name pattern in the user's home "
    "directory. When troubleshooting a printer, check both get_printer_status AND "
    "get_print_queue -- a stuck job in the queue is the most common cause of a "
    "printer that will not print. "
    "Use list_installed_applications first if you're not sure of an "
    "app's exact name before calling open_application, and list_open_windows first "
    "if you're not sure of a window's exact name before calling close_window. You "
    "cannot run arbitrary commands, install or remove "
    "anything, delete files, directly add or configure a printer, change network "
    "settings, access files outside the home directory, or "
    "change settings directly. If asked to do something outside this list, "
    "say clearly and immediately that you can't do that and suggest what "
    "the user could do manually -- never ask clarifying questions as if you "
    "might be able to do it, and never claim "
    "to have done something you have no tool for."
)

# --- Desktop tools --------------------------------------------------------
#
# Two tiers, declared once in TOOL_REGISTRY below (see that section for the
# full rationale):
#
# - "auto" tools run automatically with no approval prompt. They only ever
#   report state, never change anything, so the "broad standing visibility"
#   the assistant has is scoped to *reading*, not *doing*.
# - "gated" tools change something (even just opening an app) and always
#   show an approval dialog first, every time -- never a one-time "always
#   allow". This is the "No unrestricted system access" principle from
#   ROADMAP.md's Phase 5 design principles; broader visibility doesn't
#   relax it.
#
# Every command below is a fixed argument list with no user input ever
# interpolated into it -- there is no shell-injection surface here, and
# there never should be as this list grows.


def tool_get_disk_usage():
    home = os.path.expanduser("~")
    total, used, free = shutil.disk_usage(home)
    gb = 1024**3
    return (
        f"Disk usage for {home}: {used / gb:.1f}GB used, "
        f"{free / gb:.1f}GB free, {total / gb:.1f}GB total."
    )


def tool_get_wifi_status():
    try:
        result = subprocess.run(
            ["nmcli", "-t", "-f", "ACTIVE,SSID,SIGNAL", "dev", "wifi"],
            capture_output=True,
            text=True,
            timeout=10,
        )
        for line in result.stdout.splitlines():
            if line.startswith("yes:"):
                _active, ssid, signal = line.split(":", 2)
                return f"Connected to Wi-Fi network '{ssid}', signal strength {signal}%."
        return "Not currently connected to any Wi-Fi network."
    except Exception as exc:
        return f"Could not check Wi-Fi status: {exc}"


def tool_get_printer_status():
    try:
        result = subprocess.run(
            ["lpstat", "-p"], capture_output=True, text=True, timeout=10
        )
        return result.stdout.strip() or "No printers are currently configured."
    except Exception as exc:
        return f"Could not check printer status: {exc}"


def tool_get_print_queue():
    # The queue, not just printer state -- a stuck job is the single most
    # common real-world "printer doesn't print" cause, and without this
    # the assistant could see the printer was "idle" yet had no way to
    # see the five jobs wedged in front of the user's document.
    try:
        result = subprocess.run(
            ["lpstat", "-o"], capture_output=True, text=True, timeout=10
        )
        return result.stdout.strip() or "The print queue is empty."
    except Exception as exc:
        return f"Could not check the print queue: {exc}"


def tool_cancel_print_jobs():
    # `cancel -a` clears all pending jobs on all printers -- the standard
    # fix for a wedged queue. Gated: it destroys the user's own queued
    # documents too, so it must never run without an explicit yes.
    try:
        result = subprocess.run(
            ["cancel", "-a"], capture_output=True, text=True, timeout=10
        )
        if result.returncode != 0:
            return f"Could not cancel print jobs: {result.stderr.strip() or 'unknown error'}"
        return "Cancelled all pending print jobs."
    except Exception as exc:
        return f"Could not cancel print jobs: {exc}"


def _has_internet_connectivity():
    # Raw TCP connect to a well-known DNS server -- no HTTP request, no data
    # sent anywhere, just "can we reach the internet at all". Deliberately
    # not a fetch to any URL, so there's nothing here that could leak
    # anything or depend on a particular site being up.
    try:
        with socket.create_connection(("8.8.8.8", 53), timeout=3):
            return True
    except OSError:
        return False


def tool_check_internet_connectivity():
    if _has_internet_connectivity():
        return "Yes, this computer currently has internet connectivity."
    return "No, this computer does not currently have internet connectivity."


# --- Internet fallback (general knowledge only) -----------------------------
#
# The one deliberate exception to this being an offline-first assistant: if
# nothing relevant turns up in the offline reference collections, search
# Wikipedia's own public API for general knowledge, rather than either
# guessing from training data (the passport-hallucination failure mode this
# phase already fixed once) or just giving up. Deliberately NOT extended to
# disaster/services questions -- get_disaster_info/get_services_info's "say
# so honestly, never fall back to generic knowledge" rule stays absolute for
# Vanuatu/Fiji official-procedure questions; a random web page is not a
# substitute for the human-reviewed, cited content those tools already use,
# and reintroducing an uncurated fallback there would undo that fix.
#
# Wikipedia specifically, not a general web search, because: no API key or
# scraping needed (the MediaWiki search API and REST summary endpoint are
# free, keyless, and meant for exactly this), and it's a source the model
# can cite by name and URL like everything else this assistant answers
# from -- consistent with "prefer a verified source when one exists" rather
# than synthesizing from arbitrary, unverifiable pages.
#
# Gated, not auto: this is real internet use, and per the strategic
# review's own evidence, mobile data in this region runs ~94% above the
# world median -- an unconfirmed automatic fetch is a real cost surprise
# waiting to happen, not just a policy nicety. The connectivity check is
# done inside the tool itself (not left to the model to remember to call
# check_internet_connectivity first), so this degrades honestly to "no
# internet available" even if the model skips straight to searching.

WIKIPEDIA_SEARCH_URL = "https://en.wikipedia.org/w/api.php"
WIKIPEDIA_SUMMARY_URL = "https://en.wikipedia.org/api/rest_v1/page/summary/{title}"
# Wikimedia's API etiquette requires a descriptive User-Agent identifying
# the application -- requests without one are liable to be rate-limited.
WIKIPEDIA_USER_AGENT = (
    "PacificLinuxAssistant/1.0 (offline-first Linux distribution for the "
    "Pacific Islands; local AI assistant's internet-fallback feature)"
)
MAX_INTERNET_RESULT_CHARS = 1500
INTERNET_FETCH_TIMEOUT_SECONDS = 10


def tool_search_internet(query):
    if not _has_internet_connectivity():
        return "No internet connection is currently available, so this can't be checked online."

    try:
        search_url = WIKIPEDIA_SEARCH_URL + "?" + urllib.parse.urlencode(
            {"action": "query", "list": "search", "srsearch": query, "format": "json", "srlimit": 1}
        )
        search_req = urllib.request.Request(search_url, headers={"User-Agent": WIKIPEDIA_USER_AGENT})
        with urllib.request.urlopen(search_req, timeout=INTERNET_FETCH_TIMEOUT_SECONDS) as resp:
            search_data = json.loads(resp.read())
        results = search_data.get("query", {}).get("search", [])
        if not results:
            return f"No internet results found for '{query}'."
        title = results[0]["title"]

        summary_url = WIKIPEDIA_SUMMARY_URL.format(title=urllib.parse.quote(title.replace(" ", "_")))
        summary_req = urllib.request.Request(summary_url, headers={"User-Agent": WIKIPEDIA_USER_AGENT})
        with urllib.request.urlopen(summary_req, timeout=INTERNET_FETCH_TIMEOUT_SECONDS) as resp:
            summary_data = json.loads(resp.read())

        extract = summary_data.get("extract") or ""
        if not extract:
            return f"Found '{title}' online but it had no readable summary."
        if len(extract) > MAX_INTERNET_RESULT_CHARS:
            extract = extract[:MAX_INTERNET_RESULT_CHARS] + "\n\n[...truncated...]"
        page_url = summary_data.get("content_urls", {}).get("desktop", {}).get("page", "")
        source_line = f"\n\nSource: {page_url}" if page_url else ""
        return f"From the internet (Wikipedia), article '{title}':\n\n{extract}{source_line}"
    except Exception as exc:
        return f"Could not search the internet: {exc}"


def tool_get_current_datetime():
    now = datetime.datetime.now()
    return f"Current date and time: {now.strftime('%A, %d %B %Y, %H:%M:%S')}."


def tool_get_battery_status():
    battery_dirs = glob.glob("/sys/class/power_supply/BAT*")
    if not battery_dirs:
        return "No battery detected. This looks like a desktop machine, or the battery isn't reported."
    try:
        battery = battery_dirs[0]
        with open(os.path.join(battery, "capacity")) as f:
            capacity = f.read().strip()
        with open(os.path.join(battery, "status")) as f:
            status = f.read().strip()
        return f"Battery: {capacity}% ({status})."
    except Exception as exc:
        return f"Could not read battery status: {exc}"


# --- Knowledge base (disaster-info / services-directory) ------------------
#
# The real fix for last session's passport-application hallucination: real,
# human-cited content already exists for this exact kind of question (see
# disaster-info/ and services-directory/ built earlier in Phase 2) -- it
# just wasn't wired into the assistant. Structured lookups against the same
# JSON these standalone apps already use, not embedding-based RAG: at this
# content scale (two countries, a handful of categories/hazards each) a
# vector search would add real complexity and a new way to retrieve the
# wrong passage, for no benefit over a direct, exact lookup. Revisit if the
# content library grows into something unstructured/large enough that
# structured lookups stop being enough.
#
# Two-step discover-then-drill-down shape (list categories/hazards first,
# fetch the specific one after) rather than dumping a whole country's file
# at once -- a full services-directory file is large enough (~9KB) to eat
# most of the model's context budget in one tool result otherwise.

DISASTER_INFO_DIR = "/usr/share/venu-pacific/disaster-info"
SERVICES_DIRECTORY_DIR = "/usr/share/venu-pacific/services-directory"
KNOWN_COUNTRIES = ["vanuatu", "fiji"]


def _load_country_json(base_dir, country):
    country = (country or "").strip().lower()
    if country not in KNOWN_COUNTRIES:
        return None, (
            f"No information is available for '{country}'. Currently covered: "
            + ", ".join(KNOWN_COUNTRIES) + "."
        )
    path = os.path.join(base_dir, f"{country}.json")
    if not os.path.isfile(path):
        return None, f"No content file found for {country}."
    try:
        with open(path, "r", encoding="utf-8") as f:
            return json.load(f), None
    except Exception as exc:
        return None, f"Could not read content for {country}: {exc}"


def _format_sources(sources):
    if not sources:
        return ""
    lines = [f"- {s.get('label', '?')}: {s.get('url', '?')}" for s in sources]
    return "\n\nSources:\n" + "\n".join(lines)


def tool_get_disaster_info(country, hazard=None):
    data, error = _load_country_json(DISASTER_INFO_DIR, country)
    if error:
        return error

    contacts = data.get("emergency_contacts", [])
    contacts_text = "Emergency contacts:\n" + "\n".join(
        f"- {c.get('service', '?')}: {c.get('number', '?')}" for c in contacts
    )

    hazards = data.get("hazards", {})
    if not hazard:
        available = ", ".join(h["label"] for h in hazards.values()) if hazards else "none listed"
        return (
            f"{contacts_text}\n\nAvailable hazard guidance for {data.get('name', country)}: "
            f"{available}. Ask again naming a specific hazard for detailed before/during/after "
            f"guidance."
        )

    hazard_key = hazard.strip().lower()
    if hazard_key not in hazards:
        return (
            f"{contacts_text}\n\nNo guidance found for hazard '{hazard}'. Available: "
            + ", ".join(hazards.keys())
        )

    info = hazards[hazard_key]
    sections = []
    for phase in ("before", "during", "after"):
        items = info.get(phase, [])
        if items:
            sections.append(f"{phase.upper()}:\n" + "\n".join(f"- {i}" for i in items))
    body = "\n\n".join(sections)
    return (
        f"{contacts_text}\n\n{info.get('label', hazard)} guidance for "
        f"{data.get('name', country)}:\n\n{body}"
        f"{_format_sources(data.get('sources'))}"
    )


def tool_get_services_info(country, category=None):
    data, error = _load_country_json(SERVICES_DIRECTORY_DIR, country)
    if error:
        return error

    categories = data.get("categories", {})
    if not category:
        available = ", ".join(
            f"{key} ({info.get('label', key)})" for key, info in categories.items()
        )
        return (
            f"Available service categories for {data.get('name', country)}: {available}. "
            f"Ask again naming a specific category for the actual contacts/details."
        )

    cat_key = category.strip().lower()
    if cat_key not in categories:
        return (
            f"No category '{category}' found. Available: " + ", ".join(categories.keys())
        )

    items = categories[cat_key].get("items", [])
    lines = []
    for item in items:
        parts = [f"- {item.get('name', '?')}"]
        if item.get("agency"):
            parts.append(f"  Agency: {item['agency']}")
        if item.get("location"):
            parts.append(f"  Location: {item['location']}")
        if item.get("contact"):
            parts.append(f"  Contact: {item['contact']}")
        if item.get("description"):
            parts.append(f"  {item['description']}")
        lines.append("\n".join(parts))

    body = "\n\n".join(lines) if lines else "No items listed in this category."
    return (
        f"{categories[cat_key].get('label', category)} services in {data.get('name', country)}:"
        f"\n\n{body}"
        f"{_format_sources(data.get('sources'))}"
    )


# --- Offline encyclopedia content (Vikidia + anything the user downloads
# --- via the kiwix-content/ guide, all via Kiwix) --------------------------
#
# kiwix-search / zimdump come from separate packages (kiwix-tools, zim-tools)
# from the `kiwix` package itself (kiwix-desktop, the GUI app, has no CLI) --
# confirmed by checking what `kiwix` actually depends on before assuming
# these existed. Both verified directly against the real bundled vikidia.zim
# before writing this: kiwix-search returns matching titles; zimdump show
# --url=<title> returns the article's raw HTML, stripped to plain text here
# via BeautifulSoup so it doesn't burn context budget on markup.
#
# Users can download more ZIM content (MedlinePlus, Wikipedia Vital Articles,
# Gutenberg Education/Agriculture) via kiwix-content/index.html's guide --
# rather than a filesystem-wide scan (too broad, matches nothing we've
# scoped elsewhere) or requiring a new dedicated folder (extra friction, a
# new convention users would have to learn), check the two locations that
# already matter: where bundled content ships, and where that same guide
# already sends users to download to (Firefox's default, ~/Downloads).

KIWIX_SEARCH_BIN = "/usr/bin/kiwix-search"
ZIMDUMP_BIN = "/usr/bin/zimdump"
KIWIX_CONTENT_DIRS = [
    "/usr/share/venu-pacific/kiwix-content",
    os.path.expanduser("~/Downloads"),
]
# Real end-to-end test showed a 4000-char article made the first tool-result
# prompt over 2000 tokens, which took ~70s to process alone at this model's
# speed on this hardware, before generation even started. Trimmed down --
# Vikidia articles are already written for children (ages 8-13), so a
# shorter excerpt still captures the core content for most questions.
MAX_ARTICLE_CHARS = 1500


def _discover_zim_files():
    """Maps a collection name -> ZIM file path, for every .zim found in the
    known content directories. Not a filesystem-wide search -- see the
    section comment above for why."""
    found = {}
    for directory in KIWIX_CONTENT_DIRS:
        if not os.path.isdir(directory):
            continue
        for path in glob.glob(os.path.join(directory, "*.zim")):
            name = os.path.splitext(os.path.basename(path))[0]
            found[name] = path
    return found


def _html_to_text(html_content):
    from bs4 import BeautifulSoup

    soup = BeautifulSoup(html_content, "html.parser")
    for tag in soup(["script", "style"]):
        tag.decompose()
    lines = [line.strip() for line in soup.get_text(separator="\n").splitlines()]
    return "\n".join(line for line in lines if line)


def tool_list_offline_encyclopedias():
    zims = _discover_zim_files()
    if not zims:
        return "No offline encyclopedia/reference content is currently available."
    return "Available offline collections: " + ", ".join(sorted(zims.keys()))


def tool_search_offline_encyclopedia(query, collection=None):
    zims = _discover_zim_files()
    if not zims:
        return "No offline encyclopedia/reference content is currently available."
    if collection:
        if collection not in zims:
            return f"No collection named '{collection}'. Available: " + ", ".join(sorted(zims.keys()))
        zims = {collection: zims[collection]}

    all_results = []
    for name, path in zims.items():
        try:
            result = subprocess.run(
                [KIWIX_SEARCH_BIN, path, query], capture_output=True, text=True, timeout=15
            )
            titles = [t for t in result.stdout.splitlines() if t.strip()][:5]
            all_results.extend(f"- {t} (in {name})" for t in titles)
        except Exception:
            continue

    if not all_results:
        return f"No articles found for '{query}'."
    return (
        "Matching articles. Use get_encyclopedia_article with the exact title AND "
        "collection name to read one:\n" + "\n".join(all_results[:10])
    )


def tool_get_encyclopedia_article(title, collection):
    zims = _discover_zim_files()
    if collection not in zims:
        return f"No collection named '{collection}'. Available: " + ", ".join(sorted(zims.keys()))
    zim_path = zims[collection]
    try:
        result = subprocess.run(
            [ZIMDUMP_BIN, "show", f"--url={title}", "--", zim_path],
            capture_output=True,
            text=True,
            timeout=15,
        )
        if result.returncode != 0 or not result.stdout.strip():
            return (
                f"No article found with the exact title '{title}' in '{collection}'. Use "
                "search_offline_encyclopedia first to find the correct title."
            )
        text = _html_to_text(result.stdout)
        if len(text) > MAX_ARTICLE_CHARS:
            text = text[:MAX_ARTICLE_CHARS] + "\n\n[...article truncated...]"
        return f"Article '{title}' (from {collection}):\n\n{text}"
    except Exception as exc:
        return f"Could not read the article: {exc}"


def tool_get_active_window():
    # Same main-thread requirement as tool_list_open_windows below.
    result = {}
    done = threading.Event()

    def do_it():
        try:
            screen = Wnck.Screen.get_default()
            active = screen.get_active_window()
            result["name"] = active.get_name() if active else None
        except Exception as exc:
            result["error"] = str(exc)
        done.set()
        return False

    GLib.idle_add(do_it)
    done.wait(timeout=10)

    if "error" in result:
        return f"Could not check the active window: {result['error']}"
    name = result.get("name")
    return f"The currently active window is: {name}" if name else "No window is currently active/focused."


def tool_list_open_windows():
    # Wnck (like all GDK/GTK APIs) must only be touched from the GTK main
    # thread. Tool execution happens on the background worker thread (see
    # query_assistant), so calling Wnck directly here silently returns wrong
    # results (empty list) rather than crashing -- confirmed the hard way in
    # real testing, not theoretical. Marshal the actual call onto the main
    # loop via GLib.idle_add and block this thread until it's done, same
    # pattern as the approval dialog.
    result = {}
    done = threading.Event()

    def do_it():
        try:
            # No force_update() here -- confirmed the hard way that calling
            # it from inside a GLib.idle_add callback trips Wnck's own
            # reentrancy guard (it appears to pump the main loop internally,
            # and we're already inside a main-loop callback). The screen
            # object is kept current via ordinary passive event processing
            # once the main loop has been running for a bit, which is
            # already true by the time a user is actively chatting.
            screen = Wnck.Screen.get_default()
            result["names"] = [w.get_name() for w in screen.get_windows() if w.get_name()]
        except Exception as exc:
            result["error"] = str(exc)
        done.set()
        return False

    GLib.idle_add(do_it)
    done.wait(timeout=10)

    if "error" in result:
        return f"Could not list open windows: {result['error']}"
    names = result.get("names", [])
    return "Open windows: " + ", ".join(names) if names else "No open windows detected."


def tool_close_window(name):
    # Same main-thread requirement as tool_list_open_windows above -- Wnck
    # calls (including .close()) must happen on the GTK main loop.
    result = {}
    done = threading.Event()

    def do_it():
        try:
            screen = Wnck.Screen.get_default()
            windows = {w.get_name(): w for w in screen.get_windows() if w.get_name()}
            key = (name or "").strip().lower()
            match = next((w for n, w in windows.items() if n.lower() == key), None)
            if match is None:
                candidates = [n for n in windows if key and key in n.lower()]
                if len(candidates) == 1:
                    match = windows[candidates[0]]
                elif len(candidates) > 1:
                    result["error"] = (
                        f"multiple windows match '{name}': {', '.join(candidates)}. "
                        "Be more specific."
                    )
                else:
                    result["error"] = f"no open window found matching '{name}'."
            if match is not None:
                # 0 = X11's CurrentTime convention -- there's no real GTK
                # event to pull a timestamp from here since this runs via
                # GLib.idle_add, not an event handler. Sends the window's
                # own close protocol (WM_DELETE_WINDOW), same as clicking
                # its titlebar close button -- not a forced kill, so an app
                # with unsaved work gets its normal chance to prompt/refuse.
                match.close(0)
                result["closed"] = match.get_name()
        except Exception as exc:
            result["error"] = str(exc)
        done.set()
        return False

    GLib.idle_add(do_it)
    done.wait(timeout=10)

    if "closed" in result:
        return f"Closed the window '{result['closed']}'."
    return f"Could not close window: {result.get('error', 'unknown error')}"


def tool_open_wifi_settings():
    subprocess.Popen(["nm-connection-editor"])
    return "Opened the Wi-Fi/network connection settings."


def tool_open_printer_settings():
    subprocess.Popen(["system-config-printer"])
    return "Opened the printer settings."


# --- Application launching --------------------------------------------------
#
# Launches via Gio.AppInfo, the same mechanism XFCE's own application menu
# uses to launch things -- not a raw subprocess call with a model-supplied
# command string. This only ever runs whatever Exec= a real, already-
# installed .desktop file declares; there is no way to reach it with an
# arbitrary command, which is the point (see the strategic review's "no
# arbitrary AI-generated shell commands in the first release").
#
# should_show() filters out NoDisplay/Hidden entries -- the same filter the
# application menu itself applies -- so this only ever surfaces apps a human
# would actually see and choose from, not every helper/background .desktop
# file installed on the system.


def _list_installed_apps():
    """Maps a lowercased display name -> its Gio.AppInfo, for every
    user-visible installed application."""
    apps = {}
    for info in Gio.AppInfo.get_all():
        if not info.should_show():
            continue
        apps[info.get_display_name().lower()] = info
    return apps


def tool_list_installed_applications():
    apps = _list_installed_apps()
    if not apps:
        return "No installed applications could be listed."
    names = sorted({info.get_display_name() for info in apps.values()})
    return "Installed applications: " + ", ".join(names)


def tool_open_application(name):
    apps = _list_installed_apps()
    key = (name or "").strip().lower()
    match = apps.get(key)
    if match is None:
        candidates = sorted(n for n in apps if key and key in n)
        if len(candidates) == 1:
            match = apps[candidates[0]]
        elif len(candidates) > 1:
            return (
                f"Multiple installed applications match '{name}': "
                + ", ".join(apps[n].get_display_name() for n in candidates)
                + ". Be more specific."
            )
        else:
            return f"No installed application found matching '{name}'."
    try:
        match.launch([], None)
        return f"Opened {match.get_display_name()}."
    except GLib.Error as exc:
        return f"Could not open {match.get_display_name()}: {exc}"


HOME_DIR = os.path.realpath(os.path.expanduser("~"))
MAX_READ_FILE_BYTES = 100_000
MAX_FIND_FILE_RESULTS = 50
# PDFs get their own source-size cap: the 100KB text cap would reject
# nearly every real PDF (a two-page scanned form is easily 1MB+), and
# what matters for the model isn't the file size but the extracted TEXT
# size, capped separately below to fit the context window (~3K tokens).
MAX_PDF_SOURCE_BYTES = 20_000_000
MAX_PDF_TEXT_CHARS = 12_000
PDFTOTEXT_BIN = "/usr/bin/pdftotext"


def _resolve_home_path(path):
    """Refuse anything outside the home directory -- defense in depth on
    top of normal file permissions, since the point of gating isn't just
    "can the OS technically allow this" but "should the assistant be
    reading/writing it at all"."""
    resolved = os.path.realpath(os.path.join(HOME_DIR, os.path.expanduser(path)))
    if resolved != HOME_DIR and not resolved.startswith(HOME_DIR + os.sep):
        raise ValueError(f"Refusing to access paths outside the home directory: {path}")
    return resolved


def _read_pdf(resolved, path):
    """Extracts a PDF's text layer via pdftotext (poppler-utils). Without
    this, a PDF went through the plain-text path below and fed the model
    raw binary garbage -- confirmed by inspection, worse than refusing.
    PDFs matter for this audience specifically: school worksheets and
    government forms are exactly what users will ask about."""
    if not os.path.exists(PDFTOTEXT_BIN):
        return (
            f"Cannot read PDF files on this system (pdftotext is not installed): {path}"
        )
    size = os.path.getsize(resolved)
    if size > MAX_PDF_SOURCE_BYTES:
        return f"PDF is too large to read ({size} bytes, limit {MAX_PDF_SOURCE_BYTES}): {path}"
    result = subprocess.run(
        [PDFTOTEXT_BIN, "-layout", resolved, "-"],
        capture_output=True,
        text=True,
        timeout=30,
    )
    if result.returncode != 0:
        return f"Could not extract text from {path}: {result.stderr.strip() or 'pdftotext failed'}"
    text = result.stdout.strip()
    if not text:
        return (
            f"{path} appears to contain scanned images with no extractable text "
            "layer. The text cannot be read automatically."
        )
    if len(text) > MAX_PDF_TEXT_CHARS:
        text = text[:MAX_PDF_TEXT_CHARS] + "\n\n[...document truncated...]"
    return f"Text extracted from {path}:\n\n{text}"


def tool_read_file(path):
    try:
        resolved = _resolve_home_path(path)
        if not os.path.isfile(resolved):
            return f"No such file: {path}"
        if resolved.lower().endswith(".pdf"):
            return _read_pdf(resolved, path)
        size = os.path.getsize(resolved)
        if size > MAX_READ_FILE_BYTES:
            return f"File is too large to read ({size} bytes, limit {MAX_READ_FILE_BYTES}): {path}"
        with open(resolved, "r", encoding="utf-8", errors="replace") as f:
            content = f.read()
        return f"Contents of {path}:\n\n{content}"
    except ValueError as exc:
        return str(exc)
    except Exception as exc:
        return f"Could not read {path}: {exc}"


def tool_write_file(path, content):
    try:
        resolved = _resolve_home_path(path)
        os.makedirs(os.path.dirname(resolved), exist_ok=True)
        with open(resolved, "w", encoding="utf-8") as f:
            f.write(content)
        return f"Wrote {len(content)} characters to {path}."
    except ValueError as exc:
        return str(exc)
    except Exception as exc:
        return f"Could not write {path}: {exc}"


def tool_find_file(pattern, scope=None):
    try:
        base = _resolve_home_path(scope) if scope else HOME_DIR
    except ValueError as exc:
        return str(exc)
    if not os.path.isdir(base):
        return f"No such directory: {scope}"

    matches = []
    pattern_lower = pattern.lower()
    for root, _dirs, files in os.walk(base):
        for name in files:
            if fnmatch.fnmatch(name.lower(), pattern_lower):
                matches.append(os.path.relpath(os.path.join(root, name), HOME_DIR))
                if len(matches) >= MAX_FIND_FILE_RESULTS:
                    break
        if len(matches) >= MAX_FIND_FILE_RESULTS:
            break

    if not matches:
        return f"No files matching '{pattern}' found under {scope or '~'}."
    suffix = f" (showing first {MAX_FIND_FILE_RESULTS})" if len(matches) >= MAX_FIND_FILE_RESULTS else ""
    return f"Files matching '{pattern}'{suffix}:\n" + "\n".join(f"- {m}" for m in matches)


# --- Tool registry ----------------------------------------------------------
#
# Single source of truth for every tool the assistant can call. Before this,
# adding or changing a tool meant hand-editing up to four separate places --
# the TOOLS JSON-schema list, the READ_ONLY_TOOLS or GATED_TOOLS dispatch
# dict, and (for gated tools) GATED_TOOL_DESCRIPTIONS too -- with nothing
# enforcing they stayed in sync. That's a real correctness risk (e.g.
# registering a tool's schema but forgetting to also gate it) as the tool
# list keeps growing. Every tool is declared exactly once below; the schema
# list and dispatch dicts the rest of the app uses are all derived from it.
#
# Each entry's "tier" is one of:
#   - "auto":  runs immediately, no prompt. Only ever reports state.
#   - "gated": shows a Yes/No approval dialog every time, no "always
#     allow". Changes something, even just opening a settings app.
# See the "Desktop tools" comment above for the reasoning behind that split.
#
# Deliberately no third "prohibited" tier as data here, unlike the richer
# prohibited/explicit-approval/regular model this design was inspired by
# (Claude Code's own tool permissions). Every action this assistant has no
# tool for at all -- deleting files, running arbitrary commands, installing
# packages, changing system settings directly -- is already prohibited
# simply by never appearing in this registry, enforced by SYSTEM_PROMPT's
# instruction to decline anything outside this list. A data-driven
# "prohibited" tier would have zero members and add a layer for nothing;
# revisit only if a genuinely destructive-but-sometimes-wanted tool shows up
# that needs stricter-than-"gated" handling (e.g. a second confirmation, or
# a cooldown) that plain gating can't express.
#
# "describe" is only meaningful for gated tools: a function of the call's
# arguments -> the human-readable approval text shown in the dialog. A
# generic "write_file" label would hide exactly what's about to be
# overwritten, which defeats the point of asking, so file tools describe
# themselves with the actual path/content in play.


def _describe_read_file(arguments):
    return _("read the file '{path}'").format(path=arguments.get("path", "?"))


def _describe_write_file(arguments):
    path = arguments.get("path", "?")
    content = arguments.get("content", "")
    preview = content[:120] + ("…" if len(content) > 120 else "")
    exists = False
    try:
        exists = os.path.isfile(_resolve_home_path(path))
    except ValueError:
        pass
    verb = _("overwrite the existing file") if exists else _("create the file")
    return _("{verb} '{path}' with:\n\n{preview}").format(verb=verb, path=path, preview=preview)


def _describe_open_application(arguments):
    return _("open the application '{name}'").format(name=arguments.get("name", "?"))


def _describe_close_window(arguments):
    return _("close the window '{name}'").format(name=arguments.get("name", "?"))


def _describe_find_file(arguments):
    scope = arguments.get("scope")
    pattern = arguments.get("pattern", "?")
    if scope:
        return _("search '{scope}' for files matching '{pattern}'").format(scope=scope, pattern=pattern)
    return _("search your home directory for files matching '{pattern}'").format(pattern=pattern)


