TOOLS = [
    {"type": "function", "function": {"name": entry["name"], **entry["schema"]}}
    for entry in TOOL_REGISTRY
]

READ_ONLY_TOOLS = {
    entry["name"]: entry["handler"] for entry in TOOL_REGISTRY if entry["tier"] == "auto"
}

GATED_TOOLS = {
    entry["name"]: entry["handler"] for entry in TOOL_REGISTRY if entry["tier"] == "gated"
}

GATED_DESCRIBERS = {
    entry["name"]: entry["describe"] for entry in TOOL_REGISTRY if entry["tier"] == "gated"
}


def _describe_gated_call(name, arguments):
    describer = GATED_DESCRIBERS.get(name)
    return describer(arguments) if describer else name


def _strip_latex_artifacts(text):
    """Small local models default to LaTeX math notation (\\text{...},
    \\times, $...$ delimiters) surprisingly often, even for plain
    arithmetic -- confirmed in practice on a simple word problem. The chat
    display is a plain GTK label with no math typesetting, so this shows
    up as literal backslash-and-brace source text instead of a readable
    equation. SYSTEM_PROMPT asks the model not to do this; this is the
    safety net for when it does anyway.

    Only strips "$" when it's immediately followed by whitespace ("$ 48"),
    never when preceded by whitespace -- that first version briefly also
    matched ordinary currency like "is $48" (a space before "$" is just
    normal sentence spacing before a price, not a LaTeX tell; caught this
    in testing before it shipped). "$ 48" is the reliable signal instead:
    nobody writes a space *between* "$" and the number for real money. A
    closing "$ 48 ... 48 $" delimiter is left alone if it isn't followed
    by whitespace -- an imperfect but safe tradeoff, and the rarer case
    now that the prompt fix handles this at the source.
    """
    text = re.sub(r"\\text\{([^}]*)\}", r"\1", text)
    text = text.replace(r"\times", "×").replace(r"\cdot", "×").replace(r"\div", "÷")
    text = re.sub(r"\\\(|\\\)|\\\[|\\\]", "", text)
    text = re.sub(r"\$(?=\s)", "", text)
    text = re.sub(r"[ \t]{2,}", " ", text)
    return text


def _accumulate_tool_call_deltas(tool_calls_state, deltas):
    """Merges one SSE chunk's tool_calls deltas into tool_calls_state (a
    dict keyed by index), following llama.cpp's own documented
    reconstruction algorithm (tools/server/tests/utils.py in the
    llama.cpp source -- confirmed directly, not assumed from generic
    OpenAI docs). Each streamed delta for a given index either introduces
    a new call (id/type, usually the whole function name in one piece,
    and maybe the first fragment of arguments) or appends more of that
    same call's arguments as a raw string fragment -- never valid JSON on
    its own until every fragment for that index has arrived and been
    concatenated in order.
    """
    for delta in deltas:
        index = delta.get("index", 0)
        entry = tool_calls_state.setdefault(
            index, {"id": "", "type": "function", "function": {"name": "", "arguments": ""}}
        )
        if delta.get("id"):
            entry["id"] = delta["id"]
        if delta.get("type"):
            entry["type"] = delta["type"]
        function_delta = delta.get("function") or {}
        if function_delta.get("name"):
            entry["function"]["name"] += function_delta["name"]
        if function_delta.get("arguments"):
            entry["function"]["arguments"] += function_delta["arguments"]


def _stream_chat_completion(payload, on_content_delta=None):
    """POSTs a chat-completion request with streaming enabled and
    reconstructs a single message dict from the SSE response, shaped
    exactly like the non-streaming API's choice.message -- confirmed
    against llama.cpp's own source (tools/server/server-chat.cpp,
    server-task.cpp), not assumed. Returns {"role": "assistant",
    "content": str|None, "tool_calls": [...] (only present if any were
    streamed)}, so query_assistant's round loop below only needed its
    transport swapped, not its own logic.

    on_content_delta, if given, is called with the full accumulated
    content string so far after every content fragment -- lets the caller
    show a reply growing in place instead of a static "Thinking..." for
    however long generation takes. Tool-call fragments don't trigger it;
    there's nothing user-readable to show until they're fully assembled.

    See LLAMA_STREAM_IDLE_TIMEOUT_SECONDS above for why this uses a much
    shorter timeout than the old single-blocking-read approach could ever
    safely use, without that meaning less patience for a genuinely slow
    reply -- it's an idle timeout now, not a total one.
    """
    payload = dict(payload, stream=True)
    req = urllib.request.Request(
        f"{SERVER_URL}/v1/chat/completions",
        data=json.dumps(payload).encode(),
        headers={"Content-Type": "application/json"},
    )

    content_parts = []
    tool_calls_state = {}

    with urllib.request.urlopen(req, timeout=LLAMA_STREAM_IDLE_TIMEOUT_SECONDS) as resp:
        for raw_line in resp:
            line = raw_line.decode("utf-8", errors="replace").rstrip("\r\n")
            if not line or line.startswith(":"):
                # Blank line between SSE events, or a bare ":" comment --
                # llama-server's --sse-ping-interval keep-alive during a
                # long stall (e.g. prompt processing before the first
                # token). Not data, but its arrival is exactly what resets
                # the idle timeout above during that stall.
                continue
            if not line.startswith("data:"):
                continue
            data = line[len("data:"):].strip()
            if data == "[DONE]":
                break
            try:
                chunk = json.loads(data)
            except json.JSONDecodeError:
                continue
            choices = chunk.get("choices") or []
            if not choices:
                continue
            delta = choices[0].get("delta") or {}

            piece = delta.get("content")
            if piece:
                content_parts.append(piece)
                if on_content_delta is not None:
                    on_content_delta("".join(content_parts))

            tool_call_deltas = delta.get("tool_calls")
            if tool_call_deltas:
                _accumulate_tool_call_deltas(tool_calls_state, tool_call_deltas)

    message = {"role": "assistant", "content": "".join(content_parts) or None}
    if tool_calls_state:
        message["tool_calls"] = [
            {
                "id": entry["id"],
                "type": entry["type"],
                "function": {
                    "name": entry["function"]["name"],
                    "arguments": entry["function"]["arguments"],
                },
            }
            for _index, entry in sorted(tool_calls_state.items())
        ]
    return message


# Set (open) whenever no prewarm is in flight. query_assistant waits on
# this before sending -- confirmed live that letting a user request queue
# server-side behind the prewarm is NOT harmless as first assumed: a
# queued request receives zero bytes (no headers, no SSE pings -- those
# only start once processing begins), so on hardware where the prefix
# eval outruns the idle timeout, the user's first message dies with
# "stopped responding" while sitting silently in the queue, killed by
# the very optimization meant to speed it up. Waiting client-side
# instead is under our control (no socket timeout applies), and costs
# nothing extra: the request then reuses the freshly cached prefix, so
# total wall time is the same as queueing -- minus the error.
_prewarm_done = threading.Event()
_prewarm_done.set()


def prewarm_prefix():
    """Best-effort: evaluates the fixed system-prompt + tool-schema
    prefix (~3,500 tokens, ~2 minutes of prompt processing cold at this
    hardware's speed) into the server's KV cache BEFORE the user sends
    anything, so their first real message only pays for its own tokens
    -- the cached prefix is reused via the server's longest-common-prefix
    matching. Doubles as the wake call when the login-started service is
    sleeping (any real request triggers its auto-reload; /health
    deliberately does not).

    Runs on a background thread after the UI is already marked ready --
    never gates the UI, only the actual sending of the first request
    (see _prewarm_done above). The finally is load-bearing: if this
    fails in any way, the event must still open or every later request
    would wait out the full gate timeout for a prewarm that already
    died. A failed prewarm only means the first real message pays the
    prefix cost itself, which was the status quo.
    """
    _prewarm_done.clear()
    try:
        _stream_chat_completion(
            {
                "messages": [{"role": "system", "content": SYSTEM_PROMPT}],
                "tools": TOOLS,
                "temperature": 0.3,
                "max_tokens": 1,
                "chat_template_kwargs": {"enable_thinking": False},
            }
        )
    except Exception:
        pass
    finally:
        _prewarm_done.set()


def query_assistant(user_text, history, request_approval, on_partial_reply=None):
    # Hold the request until any in-flight prewarm finishes -- see
    # _prewarm_done above for why sending immediately is worse, not
    # better. Bounded so a pathologically stuck prewarm can't wedge the
    # app forever; after the bound, send anyway and let the request's own
    # error handling take over.
    _prewarm_done.wait(timeout=600)

    messages = (
        [{"role": "system", "content": SYSTEM_PROMPT}]
        + history
        + [{"role": "user", "content": user_text}]
    )

    # Some documented workflows need several tool calls before an answer is
    # even possible -- e.g. "learn about X" is list_offline_encyclopedias ->
    # search_offline_encyclopedia -> get_encyclopedia_article, three calls,
    # *before* the model can write anything back. A single round budget that
    # covers both the tool calls AND the final answer (as this used to be)
    # can run out exactly on the round that should have been the answer,
    # confirmed for real: that three-call chain plus a final answer is 4
    # model queries, and a flat `range(3)` cap left zero room for the last
    # one. Fixed by budgeting tool-call rounds and the final answer
    # separately: after MAX_TOOL_ROUNDS rounds of possible tool calls, make
    # one last request with no `tools` offered at all, which forces a text
    # answer grounded in whatever's already been retrieved instead of
    # attempting a tool call that would just be dropped on the floor.
    MAX_TOOL_ROUNDS = 4
    for round_index in range(MAX_TOOL_ROUNDS + 1):
        force_final_answer = round_index == MAX_TOOL_ROUNDS
        # enable_thinking=false disables Qwen3's reasoning mode at the
        # chat-template level -- reasoning is useful for the translation
        # post-editing prototype but far too slow for chat at this
        # hardware's ~6 tok/s (hundreds of hidden <think> tokens before
        # any visible output). This replaces the old approach of appending
        # "/no_think" to the user's message text, which had a real,
        # subtle cost found while researching KV-cache behavior: the
        # suffix was added at send time but history was saved WITHOUT it,
        # so every follow-up turn's re-sent history diverged from the
        # server's cached tokens at the first user message -- silently
        # re-evaluating the whole conversation every turn instead of
        # reusing the cache. Template kwargs never touch message content,
        # so the messages array now stays byte-identical between what's
        # sent and what's saved.
        payload = {
            "messages": messages,
            "temperature": 0.3,
            "max_tokens": 500,
            "chat_template_kwargs": {"enable_thinking": False},
        }
        if not force_final_answer:
            payload["tools"] = TOOLS
        # Streamed rather than one blocking request -- see
        # LLAMA_STREAM_IDLE_TIMEOUT_SECONDS above for why. on_partial_reply
        # is wired to every round, not just the final answer -- a model
        # that streams a little content alongside/before a tool call
        # (some do) shows up immediately too, not just the last round.
        message = _stream_chat_completion(payload, on_content_delta=on_partial_reply)
        tool_calls = message.get("tool_calls")
        if not tool_calls:
            return _strip_latex_artifacts((message.get("content") or "").strip())

        messages.append(message)
        for call in tool_calls:
            name = call["function"]["name"]
            call_id = call.get("id", "")
            try:
                arguments = json.loads(call["function"].get("arguments") or "{}")
            except json.JSONDecodeError:
                arguments = {}

            if name in READ_ONLY_TOOLS:
                try:
                    result = READ_ONLY_TOOLS[name](**arguments)
                except TypeError as exc:
                    result = f"Bad arguments for {name}: {exc}"
            elif name in GATED_TOOLS:
                description = _describe_gated_call(name, arguments)
                if request_approval(description):
                    try:
                        result = GATED_TOOLS[name](**arguments)
                    except TypeError as exc:
                        result = f"Bad arguments for {name}: {exc}"
                else:
                    result = "The user did not approve this action."
            else:
                result = f"Unknown tool: {name}"
            messages.append({"role": "tool", "tool_call_id": call_id, "content": result})

    return _("Sorry, I couldn't finish that after checking a few things.")


def _wrap_message_text(text, width=52):
    """Pre-wrap text with literal newlines at a fixed character width.

    Preserves intentional paragraph breaks (blank lines) from the model's
    own formatting -- only wraps within each paragraph, not across them.
    """
    paragraphs = text.split("\n\n")
    wrapped = [
        textwrap.fill(p, width=width) if p.strip() else p for p in paragraphs
    ]
    return "\n\n".join(wrapped)


def _first_available_icon(theme, candidates):
    """First icon name from candidates that actually exists in the running
    icon theme, or None. Icon themes don't all cover every freedesktop name
    (confirmed some do, some don't -- see ROADMAP.md's UI redesign notes),
    so every icon-only button falls back to short text rather than risk a
    broken-image glyph."""
    return next((name for name in candidates if theme.has_icon(name)), None)


class PulsingLogo(Gtk.Image):
    """The Venu Pacific logo with a soft, continuous heartbeat-style pulse
    -- shown wherever the assistant wants to say "I'm working on this"
    (starting up, waiting for a reply) without needing any words.

    GTK3's CSS engine only animates on state changes (hover, active, etc.)
    -- there's no free-running @keyframes loop to lean on for a continuous
    idle animation -- so this drives the pulse from Python instead, ticking
    the whole widget's opacity up and down via GLib.timeout_add. The timer
    starts/stops itself off the widget's own map/unmap signals, so a caller
    just needs to show()/hide() this like any other widget and the
    animation follows -- no separate start/stop bookkeeping to forget.
    """

    TICK_MS = 60
    MIN_OPACITY = 0.35

    def __init__(self, size=28):
        super().__init__()
        if os.path.exists(LOGO_PATH):
            pixbuf = GdkPixbuf.Pixbuf.new_from_file_at_scale(LOGO_PATH, size, size, True)
            self.set_from_pixbuf(pixbuf)
        self._phase = 0.0
        self._timeout_id = None
        self.connect("map", self._on_map)
        self.connect("unmap", self._on_unmap)

    def _on_map(self, *_args):
        if self._timeout_id is None:
            self._timeout_id = GLib.timeout_add(self.TICK_MS, self._tick)

    def _on_unmap(self, *_args):
        if self._timeout_id is not None:
            GLib.source_remove(self._timeout_id)
            self._timeout_id = None

    def _tick(self):
        self._phase += 0.18
        wave = (math.sin(self._phase) + 1) / 2  # 0..1
        self.set_opacity(self.MIN_OPACITY + wave * (1.0 - self.MIN_OPACITY))
        return True


class AssistantWindow(Gtk.Window):
    def __init__(self):
        super().__init__(title=_("Venu Pacific AI Assistant"))
        # Wider than before to make room for the chat-history sidebar
        # alongside the chat area, not instead of it.
        self.set_default_size(880, 640)
        self.set_position(Gtk.WindowPosition.CENTER)
        # No max-size geometry hint here (removed) -- it was a workaround
        # for window growth that turned out to be caused by a real bug
        # (see _on_reply/_wrap_message_text), not something that needed a
        # hard size cap. Keeping the hint after the real fix landed only
        # broke maximize/restore for no remaining benefit.

        self.server = LlamaServerManager()
        self.history = []
        # None means "a new, not-yet-saved conversation" -- nothing is
        # written to disk until the first reply completes (see _on_reply),
        # so quitting without sending anything never leaves an empty
        # conversation cluttering the sidebar.
        self.current_conv_id = None
        self._server_starting = False
        self.connect("destroy", self.on_destroy)

        # Touch the Wnck screen singleton now, on the main thread, at
        # startup -- it populates its window list from passive X11 event
        # processing over time, not instantly. Without this warmup, the
        # very first list_open_windows tool call (which can happen soon
        # after the window opens) can race ahead of that and see an empty
        # list. Confirmed this race in real testing, not theoretical.
        Wnck.Screen.get_default()

        outer = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
        self.add(outer)

        self.sidebar = self._build_sidebar()
        outer.pack_start(self.sidebar, False, False, 0)

        main_pane = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        main_pane.pack_start(self._build_header(), False, False, 0)
        main_pane.pack_start(self._build_chat_area(), True, True, 0)
        main_pane.pack_start(self._build_input_area(), False, False, 0)
        outer.pack_start(main_pane, True, True, 0)

        self._start_server_async()

    def _icon_button(self, icon_candidates, fallback_text, css_class, tooltip):
        """Icon-only button. Falls back to short text if none of the
        candidate icon names exist in the running icon theme -- see
        _first_available_icon."""
        button = Gtk.Button()
        button.set_relief(Gtk.ReliefStyle.NONE)
        button.get_style_context().add_class(css_class)
        button.set_tooltip_text(tooltip)
        icon_name = _first_available_icon(Gtk.IconTheme.get_default(), icon_candidates)
        if icon_name:
            button.add(Gtk.Image.new_from_icon_name(icon_name, Gtk.IconSize.BUTTON))
        else:
            button.add(Gtk.Label(label=fallback_text))
        return button

    def _build_sidebar(self):
        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        outer.get_style_context().add_class("sidebar")
        outer.set_size_request(220, -1)
        outer.set_border_width(10)

        theme = Gtk.IconTheme.get_default()

        new_chat = Gtk.Button()
        new_chat.get_style_context().add_class("new-chat-button")
        new_chat_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        new_chat_icon = _first_available_icon(theme, ("list-add-symbolic",))
        if new_chat_icon:
            new_chat_row.pack_start(
                Gtk.Image.new_from_icon_name(new_chat_icon, Gtk.IconSize.BUTTON), False, False, 0
            )
        new_chat_row.pack_start(Gtk.Label(label=_("New chat")), False, False, 0)
        new_chat.add(new_chat_row)
        new_chat.connect("clicked", self.on_new_chat)
        # Disabled until the assistant is actually ready -- "New chat" (and
        # switching conversations below) clears the chat area, which would
        # destroy the "Try again" retry button while a startup attempt is
        # still in progress or has just failed.
        new_chat.set_sensitive(False)
        self.new_chat_button = new_chat
        outer.pack_start(new_chat, False, False, 0)

        scroller = Gtk.ScrolledWindow()
        scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        self.conversation_list = Gtk.ListBox()
        self.conversation_list.set_selection_mode(Gtk.SelectionMode.SINGLE)
        self.conversation_list.connect("row-activated", self.on_conversation_selected)
        self.conversation_list.set_sensitive(False)
        scroller.add(self.conversation_list)
        outer.pack_start(scroller, True, True, 0)

        self._refresh_conversation_list()

        return outer

    def _refresh_conversation_list(self):
        """Rebuilds the sidebar from disk. Cheap enough to call after every
        save/delete rather than try to patch the list in place -- conversation
        counts here are small (personal local history, not a shared system)."""
        for child in self.conversation_list.get_children():
            child.destroy()

        theme = Gtk.IconTheme.get_default()
        delete_icon = _first_available_icon(
            theme, ("user-trash-symbolic", "edit-delete-symbolic")
        )

        selected_row = None
        for conv in _list_conversations():
            row = Gtk.ListBoxRow()
            row.conv_id = conv["id"]

            box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=4)
            box.set_border_width(6)

            title = Gtk.Label(label=conv["title"], xalign=0)
            title.set_ellipsize(Pango.EllipsizeMode.END)
            title.get_style_context().add_class("conversation-title")
            box.pack_start(title, True, True, 0)

            delete_button = Gtk.Button()
            delete_button.set_relief(Gtk.ReliefStyle.NONE)
            delete_button.get_style_context().add_class("delete-button")
            delete_button.set_tooltip_text(_("Delete conversation"))
            if delete_icon:
                delete_button.add(Gtk.Image.new_from_icon_name(delete_icon, Gtk.IconSize.MENU))
            else:
                delete_button.add(Gtk.Label(label="✕"))
            # A button click inside a ListBoxRow is consumed by the button
            # itself, not the row -- confirmed this doesn't also fire
            # row-activated (which would reload the conversation right
            # before deleting it).
            delete_button.connect("clicked", self._on_delete_conversation_clicked, conv["id"])
            box.pack_start(delete_button, False, False, 0)

            row.add(box)
            self.conversation_list.add(row)
            if conv["id"] == self.current_conv_id:
                selected_row = row

        self.conversation_list.show_all()
        if selected_row is not None:
            # select_row() only changes selection state, it does not fire
            # row-activated -- this highlights the active conversation
            # without triggering a reload of what's already on screen.
            self.conversation_list.select_row(selected_row)

    def _show_confirm_dialog(self, heading, body, confirm_label, is_destructive=False):
        """Themed replacement for Gtk.MessageDialog -- see the .dialog-box
        CSS comment for why. Must be called on the main thread; callers on
        a worker thread go through GLib.idle_add + threading.Event instead
        (see _request_approval)."""
        dialog = Gtk.Dialog(title=heading, transient_for=self, modal=True, destroy_with_parent=True)
        dialog.get_style_context().add_class("themed-dialog")
        dialog.set_default_size(420, -1)

        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=14)
        box.get_style_context().add_class("dialog-box")
        box.set_border_width(24)

        if os.path.exists(LOGO_PATH):
            pixbuf = GdkPixbuf.Pixbuf.new_from_file_at_scale(LOGO_PATH, 40, 40, True)
            logo = Gtk.Image.new_from_pixbuf(pixbuf)
            logo.set_halign(Gtk.Align.CENTER)
            box.pack_start(logo, False, False, 0)

        heading_label = Gtk.Label(label=heading, xalign=0.5, wrap=True, justify=Gtk.Justification.CENTER)
        heading_label.get_style_context().add_class("dialog-heading")
        box.pack_start(heading_label, False, False, 0)

        body_label = Gtk.Label(label=body, xalign=0.5, wrap=True, justify=Gtk.Justification.CENTER)
        body_label.get_style_context().add_class("dialog-body")
        box.pack_start(body_label, False, False, 0)

        dialog.get_content_area().set_border_width(0)
        dialog.get_content_area().add(box)

        cancel_button = dialog.add_button(_("Cancel"), Gtk.ResponseType.CANCEL)
        cancel_button.get_style_context().add_class("dialog-cancel")

        confirm_button = dialog.add_button(
            confirm_label, Gtk.ResponseType.OK
        )
        confirm_button.get_style_context().add_class(
            "dialog-confirm-danger" if is_destructive else "dialog-confirm"
        )

        dialog.show_all()
        response = dialog.run()
        dialog.destroy()
        return response == Gtk.ResponseType.OK

    def _on_delete_conversation_clicked(self, _button, conv_id):
        confirmed = self._show_confirm_dialog(
            _("Delete this conversation?"),
            _("This can't be undone."),
            _("Delete"),
            is_destructive=True,
        )
        if not confirmed:
            return

        _delete_conversation(conv_id)
        if conv_id == self.current_conv_id:
            self.on_new_chat()
        else:
            self._refresh_conversation_list()

    def on_new_chat(self, *_args):
        self.current_conv_id = None
        self.history = []
        self.conversation_list.unselect_all()
        self._show_placeholder(_("New conversation. Ask something below."))
        self.entry.grab_focus()

    def on_conversation_selected(self, _listbox, row):
        conv_id = getattr(row, "conv_id", None)
        if conv_id is None or conv_id == self.current_conv_id:
            return
        data = _load_conversation(conv_id)
        if data is None:
            # File vanished or is corrupt since the sidebar was last built --
            # drop it rather than show a dead conversation.
            self._refresh_conversation_list()
            return

        self.current_conv_id = conv_id
        self.history = data.get("messages", [])
        self._clear_chat_box()
        if not self.history:
            self._show_placeholder(_("This conversation is empty."))
        else:
            for message in self.history:
                self._add_message(message["content"], is_user=message["role"] == "user")
        GLib.idle_add(self._scroll_to_bottom)

    def _clear_chat_box(self):
        for child in self.chat_box.get_children():
            child.destroy()

    def _show_placeholder(self, text):
        self._clear_chat_box()
        label = Gtk.Label(label=text, xalign=0.5)
        label.get_style_context().add_class("status")
        self.chat_box.pack_start(label, False, False, 0)
        label.show()
        return label

    def _build_header(self):
        outer = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=14)
        outer.get_style_context().add_class("header-bar")
        outer.set_border_width(16)

        sidebar_toggle = self._icon_button(
            ("sidebar-show-symbolic", "open-menu-symbolic"),
            "☰",
            "icon-button",
            _("Show/hide chat history"),
        )
        sidebar_toggle.connect("clicked", self.on_toggle_sidebar)
        outer.pack_start(sidebar_toggle, False, False, 0)

        if os.path.exists(LOGO_PATH):
            pixbuf = GdkPixbuf.Pixbuf.new_from_file_at_scale(LOGO_PATH, 40, 40, True)
            outer.pack_start(Gtk.Image.new_from_pixbuf(pixbuf), False, False, 0)

        text_col = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)

        title = Gtk.Label(label=_("Venu Pacific AI Assistant"), xalign=0)
        title.get_style_context().add_class("title")
        text_col.pack_start(title, False, False, 0)

        disclaimer = Gtk.Label(
            label=_(
                "Offline, best-effort. Answers and translations may be "
                "inaccurate. Use Disaster Readiness or Services Directory "
                "for official information."
            ),
            xalign=0,
            wrap=True,
        )
        disclaimer.get_style_context().add_class("disclaimer")
        text_col.pack_start(disclaimer, False, False, 0)

        outer.pack_start(text_col, True, True, 0)

        return outer

    def on_toggle_sidebar(self, *_args):
        self.sidebar.set_visible(not self.sidebar.get_visible())

    def _build_chat_area(self):
        scroller = Gtk.ScrolledWindow()
        scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)

        self.chat_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        self.chat_box.set_border_width(18)
        scroller.add(self.chat_box)
        self.scroller = scroller

        status_column = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)

        self.startup_logo = PulsingLogo(size=48)
        self.startup_logo.set_halign(Gtk.Align.CENTER)
        status_column.pack_start(self.startup_logo, False, False, 0)

        self.status_label = Gtk.Label(label=_("Starting the assistant…"), xalign=0.5)
        self.status_label.get_style_context().add_class("status")
        status_column.pack_start(self.status_label, False, False, 0)

        # Hidden until a startup attempt actually fails -- lets the user
        # retry in place instead of having to close and reopen the whole
        # window (which is what actually fixes a startup timeout, since it
        # forces a fresh llama-server process after the page cache is warm).
        self.retry_button = Gtk.Button(label=_("Try again"))
        self.retry_button.set_halign(Gtk.Align.CENTER)
        self.retry_button.connect("clicked", self.on_retry_start)
        self.retry_button.set_no_show_all(True)
        self.retry_button.hide()
        status_column.pack_start(self.retry_button, False, False, 0)

        self.chat_box.pack_start(status_column, False, False, 0)

        return scroller

    def _build_input_area(self):
        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        row.set_border_width(14)

        self.entry = Gtk.Entry()
        self.entry.set_placeholder_text(_("Ask something…"))
        self.entry.set_sensitive(False)
        self.entry.connect("activate", self.on_send)
        row.pack_start(self.entry, True, True, 0)

        self.send_button = self._icon_button(
            ("mail-send-symbolic", "document-send-symbolic", "go-next-symbolic"),
            "➤",
            "send-button",
            _("Send"),
        )
        self.send_button.set_sensitive(False)
        self.send_button.connect("clicked", self.on_send)
        row.pack_start(self.send_button, False, False, 0)

        return row

    def _start_server_async(self):
        self._server_starting = True
        self._server_start_time = time.time()
        self.retry_button.hide()
        self.startup_logo.show()
        GLib.timeout_add(1000, self._tick_starting_label)

        def worker():
            try:
                self.server.start()
                self.server.wait_ready()
            except AssistantStartupError as exc:
                # Kill whatever's left of this attempt (e.g. a still-loading
                # llama-server that just ran out of patience) rather than
                # leave it running in the background until the window is
                # closed -- matters now that "Try again" can retry without
                # closing the window at all.
                self.server.stop()
                GLib.idle_add(self._on_server_ready, str(exc))
                return
            except Exception as exc:  # noqa: BLE001 -- must never fail silently here
                self.server.stop()
                GLib.idle_add(self._on_server_ready, str(exc))
                return
            GLib.idle_add(self._on_server_ready, None)

        threading.Thread(target=worker, daemon=True).start()

    def _tick_starting_label(self):
        """Ticks the "Starting..." label with elapsed seconds so a slow
        cold-cache model load (see STARTUP_TIMEOUT_SECONDS) doesn't look
        like the app has frozen for up to a few minutes."""
        if not self._server_starting:
            return False
        elapsed = int(time.time() - self._server_start_time)
        self.status_label.set_text(_("Starting the assistant… ({elapsed}s)").format(elapsed=elapsed))
        return True

    def on_retry_start(self, *_args):
        self._start_server_async()

    def _on_server_ready(self, error):
        self._server_starting = False
        self.startup_logo.hide()
        if error is None:
            self.status_label.set_text(_("Ready. Ask a question below."))
            self.retry_button.hide()
            self.entry.set_sensitive(True)
            self.send_button.set_sensitive(True)
            self.new_chat_button.set_sensitive(True)
            self.conversation_list.set_sensitive(True)
            self.entry.grab_focus()
            # Start evaluating the fixed prompt prefix in the background
            # while the user is still reading/typing -- see prewarm_prefix.
            # Deliberately after the UI is marked ready, never gating it.
            # The gate is closed HERE, synchronously on the main thread,
            # before the thread starts -- clearing it inside the thread
            # would leave a window where a fast user send slips past the
            # gate before the thread gets scheduled, recreating the exact
            # queued-behind-prewarm timeout this prevents.
            _prewarm_done.clear()
            threading.Thread(target=prewarm_prefix, daemon=True).start()
        else:
            self.status_label.set_text(_("Could not start the assistant: {error}").format(error=error))
            self.retry_button.show()
        return False

    def _add_message(self, text, is_user, is_thinking=False):
        column = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        column.set_halign(Gtk.Align.END if is_user else Gtk.Align.START)

        # .upper() here since GTK's CSS engine doesn't support text-transform
        # (that's a web-CSS-only property) -- the uppercase styling has to
        # happen in Python instead.
        role_text = (_("You") if is_user else _("Assistant")).upper()
        role = Gtk.Label(label=role_text, xalign=1 if is_user else 0)
        role.get_style_context().add_class("role-label")
        role.get_style_context().add_class("role-user" if is_user else "role-assistant")
        column.pack_start(role, False, False, 0)

        # GtkLabel's own wrap/max-width-chars/size-request mechanisms were
        # each tried and each failed to reliably stop the window from
        # growing to fit long replies (confirmed against the real live
        # session, not just local guessing). Sidestepping the problem
        # entirely: pre-wrap the text ourselves with literal newlines before
        # it ever reaches the label, so there is no negotiation for GTK to
        # get wrong -- the label just displays lines that are already short.
        label = Gtk.Label(label=_wrap_message_text(text), xalign=0, wrap=True)
        label.set_selectable(True)
        label.set_line_wrap_mode(Gtk.WrapMode.WORD_CHAR)
        if is_thinking:
            label.get_style_context().add_class("message-thinking")
            # Small pulsing logo next to "Thinking..." -- same heartbeat
            # widget used on the startup screen, so waiting for a reply and
            # waiting for the assistant to start read as the same kind of
            # "working on it" state. Stashed on the label itself so
            # _on_reply can find and stop it once the real reply lands,
            # without needing to thread a second reference through on_send.
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
            logo = PulsingLogo(size=18)
            row.pack_start(logo, False, False, 0)
            row.pack_start(label, False, False, 0)
            label.pulsing_logo = logo
            column.pack_start(row, False, False, 0)
        else:
            label.get_style_context().add_class("message-user" if is_user else "message-assistant")
            column.pack_start(label, False, False, 0)

        self.chat_box.pack_start(column, False, False, 0)
        column.show_all()
        return label

    def _scroll_to_bottom(self):
        adj = self.scroller.get_vadjustment()
        adj.set_value(adj.get_upper())
        return False

    def on_send(self, *_args):
        text = self.entry.get_text().strip()
        if not text:
            return
        self.entry.set_text("")
        self.entry.set_sensitive(False)
        self.send_button.set_sensitive(False)
        if not self.history:
            # First message of a fresh view (either app startup's "Ready"
            # placeholder or the "New conversation" placeholder) -- clear it
            # so it doesn't linger above the real conversation.
            self._clear_chat_box()
        self._add_message(text, is_user=True)
        thinking_label = self._add_message(_("Thinking…"), is_user=False, is_thinking=True)
        GLib.idle_add(self._scroll_to_bottom)

        def worker():
            is_error = False

            def on_partial(partial_text):
                GLib.idle_add(self._on_partial_reply, thinking_label, partial_text)

            try:
                reply = query_assistant(
                    text, self.history, self._request_approval, on_partial_reply=on_partial
                )
            except (TimeoutError, socket.timeout):
                # Streaming turned this into a genuine idle timeout (see
                # LLAMA_STREAM_IDLE_TIMEOUT_SECONDS) -- this now means the
                # connection actually stalled with no data at all for that
                # long, not just "a slow reply", since a slow-but-still-
                # arriving reply keeps resetting the timer on its own.
                reply = _(
                    "Sorry, the assistant stopped responding. This can happen if "
                    "llama-server has crashed or hung. Try asking again; if it keeps "
                    "happening, the assistant may need to be restarted."
                )
                is_error = True
            except urllib.error.HTTPError as exc:
                # HTTPError is a URLError subclass, so this must be caught
                # ahead of the plain URLError handler below. str(exc) alone
                # is just the status line ("HTTP Error 400: Bad Request")
                # -- llama-server puts the actual reason in the response
                # body (e.g. a specific validation error), which is lost
                # if it isn't read here. Worth surfacing for real
                # diagnosis rather than a dead-end generic message.
                try:
                    detail = exc.read().decode("utf-8", errors="replace").strip()
                except Exception:
                    detail = ""
                # A real, confirmed failure mode (not hypothetical): the
                # fixed per-request overhead (system prompt + all tool
                # schemas) plus a long-running conversation's own history
                # can exceed the context window -- llama-server rejects
                # this with a 400 whose body mentions the context size, a
                # distinct and actionable case worth a specific message for
                # rather than a generic error, since raising the context
                # window (see LlamaServerManager.start) only pushes the
                # ceiling out, it doesn't remove it.
                if "context" in detail.lower() and (
                    "exceed" in detail.lower() or "size" in detail.lower()
                ):
                    reply = _(
                        "Sorry, this conversation has gotten long enough that the assistant "
                        "has run out of memory for it. Try starting a New Chat to continue."
                    )
                else:
                    reply = _("Sorry, something went wrong: HTTP {code} {reason}{detail}").format(
                        code=exc.code,
                        reason=exc.reason,
                        detail=f" -- {detail}" if detail else "",
                    )
                is_error = True
            except urllib.error.URLError as exc:
                if isinstance(exc.reason, (TimeoutError, socket.timeout)):
                    reply = _(
                        "Sorry, the assistant stopped responding. This can happen if "
                        "llama-server has crashed or hung. Try asking again; if it keeps "
                        "happening, the assistant may need to be restarted."
                    )
                else:
                    reply = _("Sorry, something went wrong: {error}").format(error=exc)
                is_error = True
            except Exception as exc:
                reply = _("Sorry, something went wrong: {error}").format(error=exc)
                is_error = True
            GLib.idle_add(self._on_reply, text, reply, thinking_label, is_error)

        threading.Thread(target=worker, daemon=True).start()

    def _request_approval(self, action_description):
        """Called from the background worker thread. Blocks that thread
        (never the GTK main loop) until the user answers a real dialog --
        every gated action asks every time, no "always allow"."""
        result = {}
        done = threading.Event()

        def show_dialog():
            result["allowed"] = self._show_confirm_dialog(
                _("Allow this action?"),
                _("The assistant wants to {action}.").format(action=action_description),
                _("Allow"),
            )
            done.set()
            return False

        GLib.idle_add(show_dialog)
        done.wait(timeout=120)
        return result.get("allowed", False)

    def _on_partial_reply(self, thinking_label, partial_text):
        """Called (via GLib.idle_add, so already on the main thread) for
        every streamed content fragment -- grows the reply in place
        instead of leaving a static "Thinking..." up for however long
        generation takes. Deliberately not run through
        _strip_latex_artifacts here -- that regex expects complete LaTeX
        commands, and matching against a fragment mid-command (e.g. text
        ending in "\\tex") could produce a wrong or flickering partial
        result; the final call in _on_reply below does the real cleanup
        once the full text is in.
        """
        thinking_label.set_text(_wrap_message_text(partial_text))
        self._scroll_to_bottom()
        return False

    def _on_reply(self, user_text, reply, thinking_label, is_error=False):
        pulsing_logo = getattr(thinking_label, "pulsing_logo", None)
        if pulsing_logo is not None:
            pulsing_logo.hide()
        thinking_label.set_text(_wrap_message_text(reply))
        style = thinking_label.get_style_context()
        style.remove_class("message-thinking")
        style.add_class("message-assistant")

        # A failed turn (timeout, connection error, etc.) stays visible in
        # the chat transcript above (the bubble is already on screen) but
        # must NOT be added to history or persisted -- confirmed this was
        # happening and causing a real, observed follow-on failure: after a
        # timeout, "Sorry, something went wrong: timed out" was saved as if
        # it were the assistant's genuine turn, so a follow-up "continue"
        # sent that fake turn back to the model as real context, with
        # nothing actual to continue from. Treating a failed exchange as if
        # it never happened (from the model's point of view) is the correct
        # fix, not just a longer timeout -- the user's own question stays
        # visible on screen either way since that bubble doesn't depend on
        # self.history at all.
        if not is_error:
            self.history.append({"role": "user", "content": user_text})
            self.history.append({"role": "assistant", "content": reply})

            # Persist after every completed turn, not just on switch/close, so a
            # crash or force-quit never loses more than the in-flight reply (see
            # the "Conversation persistence" section comment for why one file
            # per conversation). First reply of a fresh chat mints its id here,
            # not at chat-start, so quitting without sending anything never
            # leaves an empty conversation cluttering the sidebar.
            if self.current_conv_id is None:
                self.current_conv_id = uuid.uuid4().hex[:12]
            _save_conversation(self.current_conv_id, _make_title(self.history[0]["content"]), self.history)
            self._refresh_conversation_list()

        self.entry.set_sensitive(True)
        self.send_button.set_sensitive(True)
        self.entry.grab_focus()
        GLib.idle_add(self._scroll_to_bottom)
        return False

    def on_destroy(self, *_args):
        self.server.stop()
        Gtk.main_quit()


def main():
    provider = Gtk.CssProvider()
    provider.load_from_data(CSS)
    Gtk.StyleContext.add_provider_for_screen(
        Gdk.Screen.get_default(),
        provider,
        Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
    )

    win = AssistantWindow()
    win.show_all()
    Gtk.main()


if __name__ == "__main__":
    main()
