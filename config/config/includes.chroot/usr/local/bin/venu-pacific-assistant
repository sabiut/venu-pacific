#!/usr/bin/env python3
"""Venu Pacific AI Assistant -- offline chat assistant (Phase 5 MVP).

Router model: Qwen3-4B via llama.cpp's llama-server, spawned on demand when
this window opens and stopped when it closes -- RAM is only used while the
assistant is actually open, matching the project's low-power design
constraint for old/donated hardware (see ROADMAP.md Phase 5).

Translation is handled by directly prompting this same model rather than a
dedicated translation pipeline -- see ROADMAP.md's Phase 5 "Decision: no
dedicated translation model" section for why, and why every response here
carries a visible disclaimer rather than being treated as authoritative.
Disaster/safety information stays in the human-reviewed Disaster Readiness
and Services Directory apps; this assistant does not replace them.

This first version is a working chat MVP: on-demand model + UI. The offline
knowledge-base/RAG wiring and desktop-action allow-list are later staged
steps (see ROADMAP.md's Build staging list), not part of this pass.
"""

import datetime
import fnmatch
import gettext
import glob
import json
import math
import os
import re
import shutil
import socket
import subprocess
import textwrap
import threading
import time
import urllib.error
import urllib.parse
import urllib.request
import uuid

import gi

gi.require_version("Gtk", "3.0")
gi.require_version("Gdk", "3.0")
gi.require_version("Gio", "2.0")
gi.require_version("Wnck", "3.0")
from gi.repository import Gdk, GdkPixbuf, Gio, GLib, Gtk, Pango, Wnck  # noqa: E402

LLAMA_SERVER_BIN = "/opt/venu-pacific/llama.cpp/bin/llama-server"
MODEL_PATH = "/usr/share/venu-pacific/models/Qwen3-4B-Q4_K_M.gguf"
LOGO_PATH = "/usr/share/pixmaps/venu-pacific.png"
SERVER_PORT = 8149
SERVER_URL = f"http://127.0.0.1:{SERVER_PORT}"
# The model is a ~2.4GB file, and the very first read of it after a fresh
# boot can be far slower than later ones -- either because it's genuinely
# cold on slow/donated hardware, or (when running from a live ISO) because
# it's being decompressed out of a read-only squashfs for the first time,
# with the OS page cache only paying off from the second load onward. 90s
# was too tight a margin for that first load in practice (confirmed: a
# timed-out launch reliably succeeds immediately on retry, with no other
# change in between) -- widened to give real hardware room without hanging
# forever if llama-server is actually broken.
STARTUP_TIMEOUT_SECONDS = 240
# A fixed total-duration timeout is the wrong shape for a chat reply of
# unknown length on hardware of unknown speed -- confirmed hitting this in
# practice (a plain "write an essay about X" timed out twice in a row,
# including on retry). Root cause: llama-server's non-streaming response
# is a single JSON document that can't be sent until generation is
# entirely finished, so the client's read blocks on one giant operation
# for the whole duration -- Python's socket timeout is technically
# per-operation, but with only one operation to wait on, it behaves
# exactly like a total-duration timeout regardless of the number chosen.
#
# Fixed by streaming every request instead (see _stream_chat_completion):
# llama-server sends small SSE chunks continuously as tokens generate,
# plus a heartbeat comment every --sse-ping-interval seconds (default 30,
# confirmed in source) even during a long stall like prompt processing.
# That turns the same per-operation socket timeout into a genuine IDLE
# timeout instead -- a reply can now take as long as it needs, as long as
# it's still making progress.
#
# 300 rather than the original 90: the SSE ping only covers a request
# that is actively being PROCESSED. Two real windows send zero bytes at
# all -- no headers, no pings: (1) a request queued behind another on the
# single slot (confirmed live: the background prefix prewarm plus a user
# message sent seconds later meant the message sat silently queued for
# the ~2-minute prefix eval and died at the old 90s), and (2) the
# sleep-wake model reload, where the login service re-reads the model
# before the request starts. The prewarm gate below removes the common
# case of (1), but this budget has to cover whatever silent window
# remains on genuinely slow hardware. A true crash usually closes the
# connection (an immediate error, not a timeout), so a generous idle
# budget costs little in real hang-detection.
LLAMA_STREAM_IDLE_TIMEOUT_SECONDS = 300

gettext.bindtextdomain("venu-pacific-assistant", "/usr/share/locale")
gettext.textdomain("venu-pacific-assistant")
_ = gettext.gettext

CSS = b"""
